{
  "name": "minimal-agent",
  "version": "0.1.0",
  "description": "极简 Agent — a minimal LLM agent with a tool-use loop",
  "type": "module",
  "main": "src/agent.ts",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/agent.ts",
    "dev": "tsx watch --env-file-if-exists=.env src/agent.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
